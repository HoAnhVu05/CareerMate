# ============================================================
# CareerMate – Environment Variables
# Copy file này thành .env và điền giá trị thực vào
# KHÔNG commit file .env lên Git!
# ============================================================

# ── Database ──────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=CareerMate2024!

# ── JWT ───────────────────────────────────────────────────
# Tạo bằng lệnh: openssl rand -base64 32
JWT_SECRET=THAY_BANG_RANDOM_BASE64_STRING_32_CHARS

# ── AWS EC2 Public IP / DNS ───────────────────────────────
# Điền Public IP của EC2 instance (lấy từ AWS Console)
EC2_PUBLIC_IP=your-ec2-public-ip-here

# ── Google OAuth ──────────────────────────────────────────
# Lấy từ: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Email (Gmail SMTP) ────────────────────────────────────
# Dùng App Password (không phải mật khẩu Gmail thường)
# Cách tạo: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# ── Gemini AI ─────────────────────────────────────────────
# Lấy từ: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
